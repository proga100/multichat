# ============================================================================
#  multichat — personal multi-model chat orchestrator (BYOK, single user)
#  Copy this file to `.env` and fill in your own keys. NEVER commit `.env`.
# ============================================================================

# --- Provider API keys (your own — Bring Your Own Keys) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Model selection -------------------------------------------------------
# Each provider has a "default" (mid-tier, cheaper/faster) and a "premium"
# (smarter/pricier) model. The app uses default unless a request asks for
# premium. Change these strings to switch models — this is the ONE place.
# NOTE: verify exact model names against each provider's current docs before
# first run; these are sensible starting points, not guaranteed-live strings.

ANTHROPIC_MODEL_DEFAULT=claude-sonnet-4-6
ANTHROPIC_MODEL_PREMIUM=claude-opus-4-8
ANTHROPIC_MAX_TOKENS=1024

OPENAI_MODEL_DEFAULT=gpt-5-mini
OPENAI_MODEL_PREMIUM=gpt-5

GEMINI_MODEL_DEFAULT=gemini-2.5-flash
GEMINI_MODEL_PREMIUM=gemini-2.5-pro

# --- Synthesis (debate mode) ----------------------------------------------
# Which provider writes the final synthesis answer. One of: anthropic | openai | gemini
SYNTHESIS_PROVIDER=anthropic

# --- Telegram bot (step 8; leave blank until you build that step) ----------
# Create a bot via @BotFather to get the token.
# Get your own numeric user id via @userinfobot — the bot will ONLY answer you.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_ID=

# --- Storage / server ------------------------------------------------------
DATABASE_PATH=./multichat.db
HOST=127.0.0.1
PORT=8000
